# OSM OAuth 2.0 credentials
# Create at https://www.openstreetmap.org/oauth2/applications
# Redirect URI: urn:ietf:wg:oauth:2.0:oob
# Scopes: write_api read_prefs

# Store credentials in ~/.config/osm/credentials.json:
# {"client_id": "YOUR_CLIENT_ID", "client_secret": "YOUR_CLIENT_SECRET"}

# Optional: Override defaults
# OSM_API_BASE=https://api.openstreetmap.org/api/0.6
# OVERPASS_PRIMARY=https://overpass-api.de/api/interpreter
