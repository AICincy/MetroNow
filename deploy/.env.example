# Copy to .env (NOT committed) on the server, then `docker compose up -d`.

# Public hostname Caddy will request a Let's Encrypt cert for.
# Must already resolve (A/AAAA) to this VM's public IP before first start.
DOMAIN=metronow.example.org

# Email used for the Let's Encrypt ACME account. Used for expiry warnings.
ACME_EMAIL=you@example.org
